# =============================================================
# PRODUCTION environment for the BACKEND.
# Set these as SECRETS / env vars on your host (Render, Railway, Fly, Azure…).
# Do NOT commit real values. The frontend gets its own var (see bottom).
# =============================================================

APP_ENV=production

# Keep API docs OFF in production (don't expose the full API surface).
DOCS_ENABLED=false

# --- Database (Neon production project) ---
# Use a dedicated production Neon project/branch. sslmode=require.
DATABASE_URL=postgresql://USER:PASSWORD@HOST.neon.tech/DB?sslmode=require

# --- Auth (CRITICAL) ---
# Long random string — protects ALL tenants' logins. Generate once:
#   python -c "import secrets; print(secrets.token_hex(32))"
AUTH_SECRET=__CHANGE_ME__64_hex_chars__
ACCESS_TOKEN_EXPIRE_MINUTES=720
# Platform owner, created on first boot of an empty DB. Use a real strong password.
SEED_ADMIN_USERNAME=owner@yourco.com
SEED_ADMIN_PASSWORD=__CHANGE_ME__strong__

# --- CORS: the frontend's public URL(s), comma-separated ---
CORS_ORIGINS=https://app.yourco.com

# --- Login rate limiting ---
LOGIN_MAX_ATTEMPTS=5
LOGIN_WINDOW_SECONDS=60

# --- Embeddings (OpenAI) ---
EMBED_PROVIDER=openai
EMBED_MODEL=text-embedding-3-small
EMBED_DIM=1536
OPENAI_API_KEY=sk-...

# --- Matching LLM (Anthropic Claude) ---
LLM_PROVIDER=anthropic
LLM_MODEL=claude-opus-4-8
ANTHROPIC_API_KEY=sk-ant-...
MATCH_CONFIDENCE_THRESHOLD=0.6
MATCH_TOP_K=8

# =============================================================
# FRONTEND (set in the frontend host, e.g. Vercel project env, or as a
# Docker build-arg): points the browser app at the backend.
#   NEXT_PUBLIC_API_URL=https://api.yourco.com
# =============================================================
