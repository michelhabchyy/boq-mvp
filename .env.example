# =============================================================
# Copy this file to ".env" and fill in real values.
#   PowerShell:  Copy-Item .env.example .env
# The .env file is gitignored and must never be committed.
# =============================================================

# --- App ---
APP_ENV=development
# Interactive API docs (/docs, /redoc, /openapi.json). Keep false in production
# so the full API surface isn't exposed; set true only for local development.
DOCS_ENABLED=false

# --- Authentication (per-company copy) ----------------------
# Secret used to sign login tokens. MUST be changed per deployment to a long
# random string (e.g. `python -c "import secrets;print(secrets.token_hex(32))"`).
AUTH_SECRET=dev-insecure-change-me-please
ACCESS_TOKEN_EXPIRE_MINUTES=720
# Seed admin, created once on first startup if no users exist. Set real values
# for each company copy, then log in and create their reviewer accounts.
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=admin

# --- Database -----------------------------------------------
# OPTION A (default): Docker pgvector, exposed on host port 5433
#   (5433 avoids colliding with your native PostgreSQL 18 on 5432)
# docker-compose reads POSTGRES_* below to create the container.
POSTGRES_USER=boq
POSTGRES_PASSWORD=npg_ihQmeDGN3nf9
POSTGRES_DB=boq
DATABASE_URL=postgresql://neondb_owner:npg_ihQmeDGN3nf9@ep-purple-hill-apkd5941.c-7.us-east-1.aws.neon.tech/neondb?sslmode=require

# OPTION B: a hosted Postgres with pgvector already enabled (e.g. Neon).
# If you use this, just replace DATABASE_URL above and ignore POSTGRES_*:
# DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST/DB?sslmode=require

# --- Cloud services (added in later steps; leave blank for now) ---
# OCR for RFP ingestion (step 3)
AZURE_DOCINTEL_ENDPOINT=
AZURE_DOCINTEL_KEY=

# --- Embeddings (catalog semantic search) -------------------
# Provider for the embed interface: "openai" (real) or "stub" (offline,
# lexical-only, for dev without a key).
EMBED_PROVIDER=openai
# OpenAI embedding model. text-embedding-3-small is the cheap default;
# text-embedding-3-large gives better Arabic/English quality (still output at
# EMBED_DIM via the dimensions param, so the DB column stays the same size).
EMBED_MODEL=text-embedding-3-small
# Vector dimension. 1536 works for both 3-small and 3-large. If you CHANGE this
# after embeddings exist, the owner must call POST /catalog/embeddings/reset.
EMBED_DIM=1536

# OpenAI API key (required when EMBED_PROVIDER=openai)
OPENAI_API_KEY=
# Other embedding providers (not implemented yet)
COHERE_API_KEY=
VOYAGE_API_KEY=

# --- Matching engine (LLM) ----------------------------------
# "anthropic" (real, Claude) or "stub" (offline, picks top candidate).
LLM_PROVIDER=anthropic
LLM_MODEL=claude-opus-4-8
# Components at or below this confidence are flagged for human review.
MATCH_CONFIDENCE_THRESHOLD=0.6
# Catalog candidates retrieved per scope line and shown to the LLM.
MATCH_TOP_K=8

# Anthropic Claude API key (needed only when LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=
